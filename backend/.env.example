ENVIRONMENT=development
DEBUG=true

DATABASE_URL=postgresql+asyncpg://safespace:safespace@postgres:5432/safespace
SYNC_DATABASE_URL=postgresql+psycopg2://safespace:safespace@postgres:5432/safespace
REDIS_URL=redis://redis:6379/0

JWT_SECRET_KEY=replace-this-with-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5
LLM_MAX_TOKENS=1024

# Vector DB (RAG memory)
QDRANT_URL=http://qdrant:6333

# Celery (async workers: memory extraction, journal summarization, analytics rollups,
# message tagging, quality scoring)
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# DL model-serving microservice
ML_SERVICE_URL=http://ml-service:8100

# Voice (STT/TTS) — OpenAI Whisper + TTS; leave blank to disable voice features
OPENAI_API_KEY=

CORS_ORIGINS=["http://localhost:5173"]
